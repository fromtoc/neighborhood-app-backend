# Copy to .env and fill in real values.  NEVER commit .env to git.

# ── MySQL ──────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=ChangeMe_Root_Password
MYSQL_DATABASE=appdb
MYSQL_USER=appuser
MYSQL_PASSWORD=ChangeMe_App_Password

# ── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=ChangeMe_Redis_Password

# ── RabbitMQ ───────────────────────────────────────────────────
RABBITMQ_USER=appuser
RABBITMQ_PASSWORD=ChangeMe_Rabbit_Password

# ── JWT ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=ChangeMe_JWT_Secret_At_Least_48_Chars_Long_Base64

# ── 地址轉座標（擇一設定，TGOS 優先）──────────────────────────────
# Google Geocoding API（目前使用）
# 申請：https://console.cloud.google.com/ → Geocoding API
# GOOGLE_GEOCODING_API_KEY=your_google_geocoding_api_key
#
# TGOS（預計切換）
# 申請：https://api.tgos.tw/
# TGOS_API_KEY=your_tgos_api_key

# ── Firebase (optional) ────────────────────────────────────────
# FIREBASE_CREDENTIALS_PATH=/secrets/firebase-service-account.json
# FIREBASE_CREDENTIALS_DIR=/secrets

# ── TGOS (optional) ────────────────────────────────────────────
# TGOS_API_KEY=your_tgos_api_key
