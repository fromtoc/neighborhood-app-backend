# ================================================================
# GoLocal — 後端 + 基礎設施環境變數範本
# 使用方式：cp infra/.env.example .env，填入實際值後放在 repo 根目錄
# 注意：.env 已加入 .gitignore，絕對不要 commit 實際密鑰
# ================================================================


# ── MySQL ────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=appdb
MYSQL_USER=appuser
MYSQL_PASSWORD=change-me-db


# ── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis


# ── RabbitMQ ─────────────────────────────────────────────────────
RABBITMQ_USER=appuser
RABBITMQ_PASSWORD=change-me-mq


# ── JWT ──────────────────────────────────────────────────────────
# 產生指令：openssl rand -base64 48
JWT_SECRET=change-me-jwt-secret-at-least-32-chars


# ── Web（Next.js）Revalidate ────────────────────────────────────
# Backend 呼叫 Next.js ISR revalidate 時的驗證 token
# 必須與 web/.env.local 的 REVALIDATE_TOKEN 一致
# 產生指令：openssl rand -hex 32
WEB_REVALIDATE_URL=https://your-web-domain.com/api/revalidate
REVALIDATE_TOKEN=change-me-revalidate-secret


# ── Backend 對外 Base URL ────────────────────────────────────────
# 用於 sitemap loc、OG 圖片等絕對路徑
BASE_URL=https://api.your-domain.com


# ── Firebase Admin SDK（選填）───────────────────────────────────
# 不啟用 Firebase 登入時留空即可
FIREBASE_CREDENTIALS_PATH=
FIREBASE_CREDENTIALS_DIR=


# ── Google Geocoding API（選填）─────────────────────────────────
# /locate?address= 需要；不填則地址查詢回傳 503
GOOGLE_GEOCODING_API_KEY=


# ── LINE Login（選填）──────────────────────────────────────────
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=


# ── Admin API Token ─────────────────────────────────────────────
# Step 5 實作後啟用：X-Admin-Token header 驗證
ADMIN_TOKEN=change-me-admin-token
