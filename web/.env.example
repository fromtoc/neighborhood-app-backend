# ================================================================
# GoLocal Web（Next.js）環境變數範本
# 使用方式：cp web/.env.example web/.env.local，填入實際值
# 注意：.env.local 已加入 .gitignore，絕對不要 commit
# ================================================================


# ── Backend 連線 ─────────────────────────────────────────────────
# Server Component / Route Handler 使用（不暴露給瀏覽器）
API_BASE_URL=http://localhost:8080

# 瀏覽器端 Client Component fetch 使用
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080


# ── ISR Revalidate（Step 19 啟用）──────────────────────────────
# Backend 呼叫 POST /api/revalidate 時帶的 secret
# 必須與後端 .env 的 REVALIDATE_SECRET 一致
REVALIDATE_SECRET=change-me-revalidate-secret


# ── 站點 Base URL ────────────────────────────────────────────────
# 用於 sitemap、canonical、OG meta 等絕對路徑
NEXT_PUBLIC_SITE_URL=http://localhost:3000
